# ── HuggingFace ───────────────────────────────────────────────────────────────
# Required to download gated models (e.g. LLaMA). For public models like
# bert-base-uncased and gpt2, this can be left blank.
HF_TOKEN=

# ── Weights & Biases (optional) ───────────────────────────────────────────────
# Set to log training curves, eval metrics, and expert routing heatmaps.
# Leave blank to disable W&B logging (falls back to local CSV logs).
WANDB_API_KEY=
WANDB_PROJECT=bertdiffused
WANDB_RUN_NAME=run_001

# ── GPU selection ─────────────────────────────────────────────────────────────
# Comma-separated GPU indices, or "all". Examples:
#   NVIDIA_VISIBLE_DEVICES=0
#   NVIDIA_VISIBLE_DEVICES=0,1
#   NVIDIA_VISIBLE_DEVICES=all
NVIDIA_VISIBLE_DEVICES=all

# ── Training overrides (optional) ─────────────────────────────────────────────
# These are passed to train.py and override configs/config.yaml values.
# TRAIN_MAX_STEPS=100000
# TRAIN_BATCH_SIZE=64
# TRAIN_LR=5e-5
# TRAIN_OUTPUT_DIR=checkpoints/bertdiffused
